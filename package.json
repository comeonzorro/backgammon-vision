{
  "name": "backgammon-vision",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:live": "npm run live:server & vite",
    "live:server": "cd server && npm install && npm start",
    "build": "tsc --noEmit && vite build",
    "check:engine": "tsx scripts/checkEngine.ts",
    "build:subdir": "BASE_PATH=/backgammon-vision/ npm run build",
    "preview": "vite preview",
    "preview:subdir": "BASE_PATH=/backgammon-vision/ npm run build && vite preview"
  },
  "dependencies": {
    "hls.js": "^1.6.2",
    "onnxruntime-web": "^1.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.23.1",
    "typescript": "~5.7.2",
    "vite": "^6.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
